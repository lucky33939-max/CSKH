import { useEffect, useState } from "react";

export default function App() {
  const [stats, setStats] = useState({});

  useEffect(() => {
    fetch("http://localhost:8000/stats")
      .then(res => res.json())
      .then(setStats);
  }, []);

  return (
    <div>
      <h1>Dashboard</h1>
      <p>Users: {stats.users}</p>
      <p>Revenue: {stats.revenue}</p>
    </div>
  );
}
